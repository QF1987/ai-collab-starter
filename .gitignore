# Editor / IDE 个人配置
.obsidian/            # Obsidian vault 设置
.vscode/              # VSCode workspace 设置
.idea/                # JetBrains 系列
*.swp
*.swo
.DS_Store

# AI 协同框架的临时 / 缓存（用本框架的项目应该继承这条）
.ai/cache/
.ai/tmp/

# lite v0.1.0: Codex ↔ OC-helper 共享文件总线 (epic 结束 Human 可清空)
.ai/scratch/

# 注意：.ai/logs/ 看团队偏好是否进版本控制
# 若希望追溯历史 Agent 输出：不加
# 若 logs 体积大或含敏感信息：取消下行注释
# .ai/logs/

# 本地环境
.env
.env.local

# Claude Code user-specific settings (per-user hook overrides etc.)
.claude/settings.local.json

# 包管理器误生成（Dogfood #16）
pnpm-workspace.yaml   # pnpm 11 init 默认生成；单仓 web 项目不需要 monorepo workspace
.agents/              # 某些 AI 工具会自动生成此目录
*.lock                # 偶尔非主流包管理器留下的杂物（保留 package-lock.json / pnpm-lock.yaml / yarn.lock）
!package-lock.json
!pnpm-lock.yaml
!yarn.lock
